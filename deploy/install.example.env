# knowledgeBook 非交互部署示例配置
# 使用方法：
#   cp deploy/install.example.env deploy/install.env
#   修改 deploy/install.env
#   set -a
#   source deploy/install.env
#   set +a
#   bash deploy/scripts/bootstrap.sh --from-env

POSTGRES_DB=knowledgebook
POSTGRES_USER=knowledgebook
POSTGRES_PASSWORD=change_me
REDIS_ADDR=redis:6379
APP_PORT=8080
APP_ENV=production
APP_LOG_LEVEL=info
AUTO_CLASSIFY_TOP1_THRESHOLD=0.85
AUTO_CLASSIFY_GAP_THRESHOLD=0.15
SOFT_DELETE_RETENTION_DAYS=30
AUTO_MIGRATE=true
FEISHU_DOC_BASE_URL=https://www.feishu.cn/docx

# 是否启用飞书接入：y / n
ENABLE_FEISHU=n

# 启用飞书时需要补齐以下字段
PUBLIC_BASE_URL=https://kb.example.com
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
# 事件订阅校验 token，不是 tenant_access_token；tenant_access_token 由服务运行时自动获取
FEISHU_VERIFICATION_TOKEN=xxx
FEISHU_ENCRYPT_KEY=
