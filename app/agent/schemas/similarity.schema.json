{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SimilarityJudgement",
  "type": "object",
  "required": ["relation_type", "score", "reason", "suggested_action"],
  "properties": {
    "relation_type": {
      "type": "string",
      "enum": ["merge_candidate", "supplement_candidate", "conflict_candidate", "new_knowledge"]
    },
    "score": {"type": "number", "minimum": 0, "maximum": 1},
    "reason": {"type": "string"},
    "suggested_action": {"type": "string"}
  },
  "additionalProperties": false
}