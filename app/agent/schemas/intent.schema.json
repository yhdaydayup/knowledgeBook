{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IntentUnderstandingResult",
  "type": "object",
  "required": ["intent", "confidence", "needs_clarification", "slots"],
  "properties": {
    "intent": {
      "type": "string",
      "enum": ["create_knowledge", "approve_pending_draft", "reject_pending_draft", "change_pending_draft_category", "search_knowledge", "check_similarity", "clarify"]
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "needs_clarification": {"type": "boolean"},
    "action": {"type": "string"},
    "response_mode": {"type": "string", "enum": ["text", "card", "text_and_card"]},
    "slots": {"type": "object", "additionalProperties": true}
  },
  "additionalProperties": false
}